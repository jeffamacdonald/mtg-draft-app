<%= turbo_frame_tag "modal" do %>
  <div class="modal d-block" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <%= render(ButtonComponent.new(classes: "ms-auto", variation: :close, data: { controller: "modal", action: "modal#close"})) %>
        <div class="text-center">ARE YOU SURE?</div>
        <% if @draft_participant.user != current_user %>
          <div class="text-center text-danger">Picking for <%= @draft_participant.display_name %></div>
        <% end %>
        <div class="pt-3 row justify-content-center">
          <%= image_tag(@cube_card.image_url, class: "cube_card__img__static") %>
          <%= render(ScryfallLinkComponent.new(card: @cube_card.card)) %>
        </div>
        <div class="row justify-content-center mt-2 gx-3">
          <div class="col-4">
            <%= form_with(model: ParticipantPick.new, id: "pick_form") do |f| %>
              <%= f.hidden_field :draft_participant_id, value: @draft_participant.id %>
              <%= f.hidden_field :cube_card_id, value: @cube_card.id %>
              <%= render(ButtonComponent.new(variation: :primary, classes: "mb-2 w-100", data: { turbo: false })) { "Pick" } %>
            <% end %>
          </div>
          <% participant_for_queue = @draft_participant.user == current_user ? @draft_participant : DraftParticipant.find_by(user: current_user, draft: @draft_participant.draft) %>
          <% queued_pick = participant_for_queue.queued_picks.find { |qp| qp.cube_card_id == @cube_card.id } %>
          <% if queued_pick.present? %>
            <div class="col-5">
              <%= form_with(model: queued_pick, method: :delete, id: "remove_from_queue_form") do %>
                <%= render(ButtonComponent.new(variation: :danger, classes: "mb-2 w-100")) { "Remove from Queue" } %>
              <% end %>
            </div>
          <% else %>
            <div class="col-4">
              <%= form_with(model: QueuedPick.new, id: "add_to_queue_form") do |f| %>
                <%= f.hidden_field :draft_participant_id, value: @draft_participant.id %>
                <%= f.hidden_field :cube_card_id, value: @cube_card.id %>
                <%= f.hidden_field :priority_number, value: (@draft_participant.queued_picks.maximum(:priority_number) || 0) + 1 %>
                <%= render(ButtonComponent.new(variation: :secondary, classes: "mb-2 w-100")) { "Add to Queue" } %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
